b:["$","div",null,{"className":"mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_18rem]","children":[["$","article",null,{"className":"space-y-4","children":[["$","div",null,{"id":"introduction","className":"interactive-panel rounded-[28px] p-6","children":["$","p",null,{"className":"text-base leading-8 text-slate-700 dark:text-slate-200","children":"GST mistakes often happen in simple places: quoting tax-inclusive prices incorrectly, applying the wrong rate, or mixing up taxable value and invoice total. A calculator helps, but the inputs still need care."}]}],[["$","section","Confusing inclusive and exclusive pricing",{"id":"confusing-inclusive-and-exclusive-pricing","className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"Confusing inclusive and exclusive pricing"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","p","One of the most common errors is adding GST again to a price that already includes it. That leads to overcharging, invoice mismatches, and awkward corrections later.",{"children":"One of the most common errors is adding GST again to a price that already includes it. That leads to overcharging, invoice mismatches, and awkward corrections later."}],["$","p","A clear workflow helps: first decide whether the quoted amount is tax inclusive or tax exclusive, then use the correct calculation path consistently.",{"children":"A clear workflow helps: first decide whether the quoted amount is tax inclusive or tax exclusive, then use the correct calculation path consistently."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","li","Mark price sheets clearly as inclusive or exclusive",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Mark price sheets clearly as inclusive or exclusive"}],["$","li","Double-check invoice templates before sharing them",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Double-check invoice templates before sharing them"}],["$","li","Keep the tax component visible for reconciliation",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Keep the tax component visible for reconciliation"}]]}]]}],["$","section","Using the wrong rate or category",{"id":"using-the-wrong-rate-or-category","className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"Using the wrong rate or category"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","p","The right math still produces the wrong answer if the rate itself is incorrect. Teams often copy old invoice settings forward without checking if the product or service category changed.",{"children":"The right math still produces the wrong answer if the rate itself is incorrect. Teams often copy old invoice settings forward without checking if the product or service category changed."}],["$","p","Whenever classification is unclear, confirm it before billing at scale instead of patching multiple invoices later.",{"children":"Whenever classification is unclear, confirm it before billing at scale instead of patching multiple invoices later."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","li","Review tax settings when adding new offerings",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Review tax settings when adding new offerings"}],"$Ld","$Le"]}]]}],"$Lf"],"$L10","$L11","$L12","$L13"]}],"$L14"]}]
