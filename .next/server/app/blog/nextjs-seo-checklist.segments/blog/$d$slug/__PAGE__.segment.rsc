9:["$","section","Support discovery with internal links and performance",{"id":"support-discovery-with-internal-links-and-performance","className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"Support discovery with internal links and performance"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","p","Visitors should be able to move from a homepage to categories, tools, blog posts, and policy pages without friction. That same structure helps crawlers understand the site.",{"children":"Visitors should be able to move from a homepage to categories, tools, blog posts, and policy pages without friction. That same structure helps crawlers understand the site."}],["$","p","Performance remains a quality signal too. Lightweight pages, clear layouts, and fewer dead ends improve both indexing and user satisfaction.",{"children":"Performance remains a quality signal too. Lightweight pages, clear layouts, and fewer dead ends improve both indexing and user satisfaction."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","li","Link related tools and related blog posts",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Link related tools and related blog posts"}],["$","li","Keep important pages accessible from the header or footer",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Keep important pages accessible from the header or footer"}],["$","li","Avoid placeholder copy on production routes",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Avoid placeholder copy on production routes"}]]}]]}]
a:["$","section",null,{"className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"Frequently asked questions"}],["$","div",null,{"className":"mt-4 space-y-4","children":[["$","div","Do utility websites need blog content?",{"className":"rounded-2xl border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-950","children":[["$","h3",null,{"className":"text-base font-semibold text-slate-900 dark:text-slate-100","children":"Do utility websites need blog content?"}],["$","p",null,{"className":"mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":"They do not need a blog purely for volume, but they benefit from explanatory content that answers adjacent user questions and shows editorial depth."}]]}],["$","div","Is structured data enough to rank better?",{"className":"rounded-2xl border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-950","children":[["$","h3",null,{"className":"text-base font-semibold text-slate-900 dark:text-slate-100","children":"Is structured data enough to rank better?"}],["$","p",null,{"className":"mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":"No. Structured data helps clarify page meaning, but rankings still depend on content quality, intent match, performance, and overall site trust."}]]}]]}]]}]
