b:["$","div",null,{"className":"mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_18rem]","children":[["$","article",null,{"className":"space-y-4","children":[["$","div",null,{"id":"introduction","className":"interactive-panel rounded-[28px] p-6","children":["$","p",null,{"className":"text-base leading-8 text-slate-700 dark:text-slate-200","children":"Tool websites often focus on functionality first and forget the signals search engines and reviewers expect. A good SEO baseline is not just metadata - it is also content depth, internal linking, crawlable routes, and trust-building pages."}]}],[["$","section","Start with page intent, not just keywords",{"id":"start-with-page-intent-not-just-keywords","className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"Start with page intent, not just keywords"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","p","Each tool page should clearly explain what the tool does, who it is for, and what output a visitor can expect. Thin pages struggle even when the tool itself works well.",{"children":"Each tool page should clearly explain what the tool does, who it is for, and what output a visitor can expect. Thin pages struggle even when the tool itself works well."}],["$","p","Blog pages, FAQs, and category summaries give you room to answer surrounding questions that users naturally search for.",{"children":"Blog pages, FAQs, and category summaries give you room to answer surrounding questions that users naturally search for."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","li","Add a unique title and description for every page",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Add a unique title and description for every page"}],["$","li","Write supporting copy that explains use cases and limitations",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Write supporting copy that explains use cases and limitations"}],["$","li","Use clean headings so content is easy to scan",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Use clean headings so content is easy to scan"}]]}]]}],["$","section","Make metadata and structured data consistent",{"id":"make-metadata-and-structured-data-consistent","className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"Make metadata and structured data consistent"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","p","Canonical URLs, Open Graph tags, and schema markup should all point to the same page identity. Inconsistent signals make indexing and sharing harder than they need to be.",{"children":"Canonical URLs, Open Graph tags, and schema markup should all point to the same page identity. Inconsistent signals make indexing and sharing harder than they need to be."}],["$","p","Structured data is especially useful on tool and article pages because it helps communicate page purpose more directly.",{"children":"Structured data is especially useful on tool and article pages because it helps communicate page purpose more directly."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","li","Set canonical URLs from a real production domain",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Set canonical URLs from a real production domain"}],"$Ld","$Le"]}]]}],"$Lf"],"$L10","$L11","$L12","$L13"]}],"$L14"]}]
