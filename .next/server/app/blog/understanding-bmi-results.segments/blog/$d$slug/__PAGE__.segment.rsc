5:["$","div",null,{"className":"mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_18rem]","children":[["$","article",null,{"className":"space-y-4","children":[["$","div",null,{"id":"introduction","className":"interactive-panel rounded-[28px] p-6","children":["$","p",null,{"className":"text-base leading-8 text-slate-700 dark:text-slate-200","children":"BMI is popular because it is simple, not because it is complete. The number can be useful, but only when it is kept in proportion to everything it does not measure."}]}],[["$","section","What BMI is good for",{"id":"what-bmi-is-good-for","className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"What BMI is good for"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","p","BMI gives a fast, standardized way to combine height and weight into one broad reference point. That can be helpful for screening, trend tracking, and starting conversations.",{"children":"BMI gives a fast, standardized way to combine height and weight into one broad reference point. That can be helpful for screening, trend tracking, and starting conversations."}],["$","p","Its usefulness comes from simplicity. In a few seconds, people can move from vague impressions to a metric they can revisit over time.",{"children":"Its usefulness comes from simplicity. In a few seconds, people can move from vague impressions to a metric they can revisit over time."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","li","Useful as a broad baseline",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Useful as a broad baseline"}],["$","li","Helpful for trend awareness",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Helpful for trend awareness"}],["$","li","Easy to calculate repeatedly",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Easy to calculate repeatedly"}]]}]]}],["$","section","What BMI does not capture well",{"id":"what-bmi-does-not-capture-well","className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"What BMI does not capture well"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","p","BMI does not distinguish muscle from fat, describe body composition, or account for individual medical context. That is why the same BMI can mean different things for different people.",{"children":"BMI does not distinguish muscle from fat, describe body composition, or account for individual medical context. That is why the same BMI can mean different things for different people."}],["$","p","Treating BMI as a final judgment can lead to confusion, overreaction, or misplaced reassurance.",{"children":"Treating BMI as a final judgment can lead to confusion, overreaction, or misplaced reassurance."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","li","Does not measure body composition directly",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Does not measure body composition directly"}],["$","li","Misses context like age, training status, and medical history",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Misses context like age, training status, and medical history"}],"$L7"]}]]}],"$L8"],"$L9","$La","$Lb","$Lc"]}],"$Ld"]}]
