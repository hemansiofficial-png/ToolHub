5:["$","div",null,{"className":"mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_18rem]","children":[["$","article",null,{"className":"space-y-4","children":[["$","div",null,{"id":"introduction","className":"interactive-panel rounded-[28px] p-6","children":["$","p",null,{"className":"text-base leading-8 text-slate-700 dark:text-slate-200","children":"A good image file is not just about visual quality. It also needs to load quickly, fit the target layout, and stay easy to upload where it is going next."}]}],[["$","section","Resize before you compress when dimensions are oversized",{"id":"resize-before-you-compress-when-dimensions-are-oversized","className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"Resize before you compress when dimensions are oversized"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","p","One of the simplest ways to reduce image weight is to stop carrying more pixels than the destination needs. A large source file may look impressive, but if the website or form only displays a smaller box, the extra dimensions are rarely helping.",{"children":"One of the simplest ways to reduce image weight is to stop carrying more pixels than the destination needs. A large source file may look impressive, but if the website or form only displays a smaller box, the extra dimensions are rarely helping."}],["$","p","Resizing first often produces cleaner final results than repeatedly over-compressing a file that is simply too large in shape.",{"children":"Resizing first often produces cleaner final results than repeatedly over-compressing a file that is simply too large in shape."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","li","Match the destination dimensions early",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-