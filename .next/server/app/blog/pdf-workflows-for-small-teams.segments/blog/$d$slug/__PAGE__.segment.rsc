6:["$","div",null,{"className":"mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_18rem]","children":[["$","article",null,{"className":"space-y-4","children":[["$","div",null,{"id":"introduction","className":"interactive-panel rounded-[28px] p-6","children":["$","p",null,{"className":"text-base leading-8 text-slate-700 dark:text-slate-200","children":"Document work becomes expensive when every small change requires a specialist or a paid desktop app. Many PDF tasks are repetitive enough that a simple browser-first workflow is all a small team needs."}]}],[["$","section","Map the common jobs before you buy software",{"id":"map-the-common-jobs-before-you-buy-software","className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"Map the common jobs before you buy software"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","p","Most teams do the same few things repeatedly: combine files, extract pages, convert scans to PDFs, or shrink oversized attachments. Those needs often justify a lightweight workflow before a complex tool rollout.",{"children":"Most teams do the same few things repeatedly: combine files, extract pages, convert scans to PDFs, or shrink oversized attachments. Those needs often justify a lightweight workflow before a complex tool rollout."}],["$","p","Start by listing the document tasks that happen every week. You will usually find that only a small set of utilities is needed to remove most of the friction.",{"children":"Start by listing the document tasks that happen every week. You will usually find that only a small set of utilities is needed to remove most of the friction."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","li","Merge packets for clients or approvals",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Merge packets for clients or approvals"}],["$","li","Split large source files before sharing",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Split large source files before sharing"}],["$","li","Compress outputs at the final delivery step",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Compress outputs at the final delivery step"}]]}]]}],["$","section","Use the right sequence",{"id":"use-the-right-sequence","className":"interactive-panel rounded-[28px] p-6","children":[["$","h2",null,{"className":"text-2xl font-semibold text-slate-950 dark:text-slate-50","children":"Use the right sequence"}],["$","div",null,{"className":"mt-4 space-y-4 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","p","The order of operations matters. If several images need to become one file, convert them first, then compress the finished PDF if size is still an issue.",{"children":"The order of operations matters. If several images need to become one file, convert them first, then compress the finished PDF if size is still an issue."}],["$","p","Likewise, if a large document contains only a few relevant pages, split first so you are not compressing or sharing unnecessary content.",{"children":"Likewise, if a large document contains only a few relevant pages, split first so you are not compressing or sharing unnecessary content."}]]}],["$","ul",null,{"className":"mt-4 space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300","children":[["$","li","Convert or merge before compressing when possible",{"className":"rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-900","children":"Convert or merge before compressing when possible"}],"$L8","$L9"]}]]}],"$La"],"$Lb","$Lc","$Ld","$Le"]}],"$Lf"]}]
